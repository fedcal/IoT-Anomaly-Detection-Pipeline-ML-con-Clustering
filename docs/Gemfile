# Gemfile per build locale della documentazione
# (GitHub Pages builda lato server con la sua versione di Jekyll: questo
#  Gemfile serve solo se vuoi testare in locale con `bundle exec jekyll serve`).
#
# Setup locale:
#   gem install bundler
#   bundle install
#   bundle exec jekyll serve --livereload
#   # apri http://127.0.0.1:4000/iot-anomaly-detection-clustering/

source "https://rubygems.org"

# Stack ufficiale GitHub Pages (allinea Jekyll/plugin alla versione runtime)
gem "github-pages", group: :jekyll_plugins

# Plugin extra (già whitelisted da GitHub Pages)
group :jekyll_plugins do
  gem "jekyll-remote-theme"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-include-cache"
end

# Windows / JRuby (innocuo su Linux/macOS)
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswin]
